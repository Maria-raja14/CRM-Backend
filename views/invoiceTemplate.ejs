<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Invoice</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: Arial, sans-serif;
        font-size: 12px;
        color: #333;
        background: #fff;
      }
      .invoice-box {
        width: 95%;
        margin: auto;
        padding: 30px;
        background: #fff;
      }
      .logo-wrapper {
        text-align: center;
        margin-bottom: 24px;
        min-height: 80px;
      }
      .logo {
        width: 260px;
        height: auto;
        display: inline-block;
      }
      .info-section {
        display: flex;
        justify-content: space-between;
        margin-top: 10px;
        gap: 20px;
      }
      .info-box {
        width: 48%;
        font-size: 12px;
        line-height: 1.8;
      }
      .info-box strong {
        display: block;
        font-size: 13px;
        margin-bottom: 4px;
        color: #111;
      }
      .invoice-details {
        margin-top: 20px;
        font-size: 12px;
        line-height: 2;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
      }
      table, th, td { border: 1px solid #ccc; }
      th, td { padding: 8px 10px; text-align: left; }
      th { background-color: #f5f5f5; font-weight: bold; }
      .right { text-align: right; }
      .totals {
        margin-top: 20px;
        width: 100%;
        display: flex;
        justify-content: flex-end;
      }
      .totals-table {
        width: 320px;
        border-collapse: collapse;
        font-size: 12px;
      }
      .totals-table td { padding: 6px 8px; border: none; }
      .totals-table tr td:first-child { text-align: left; color: #555; }
      .totals-table tr td:last-child  { text-align: right; font-weight: 500; }
      .totals-table tr.total-row td {
        font-weight: bold;
        font-size: 13px;
        border-top: 2px solid #333;
        padding-top: 10px;
        color: #111;
      }
      .footer {
        font-size: 10px;
        text-align: center;
        margin-top: 40px;
        color: #888;
        border-top: 1px solid #eee;
        padding-top: 14px;
      }
    </style>
  </head>
  <body>
    <div class="invoice-box">

      <!-- ✅ Logo — src is base64 passed from controller, works in ALL environments -->
      <div class="logo-wrapper">
        <% if (logoBase64) { %>
          <img src="<%= logoBase64 %>" alt="U Enjoy Tours Logo" class="logo" />
        <% } else { %>
          <p style="font-size:18px;font-weight:bold;color:#1e40af;">U Enjoy Tours</p>
        <% } %>
      </div>

      <!-- Info -->
      <div class="info-section">
        <!-- Company Info -->
        <div class="info-box">
          <strong>U Enjoy Tours</strong>
          2nd Floor, No.1721/1B, A.H.R.S Towers<br />
          Ramamurthy Nagar Main Road, Ramamurthy Nagar,<br />
          Bengaluru, Karnataka - 560016<br />
          Email: uenjoytours@gmail.com<br />
          Phone: +91 9535542288<br />
          GSTIN: 29ALYPC4718L1ZE
        </div>

        <!-- Client Info -->
        <div class="info-box" style="text-align:right;">
          <strong>Bill To:</strong>
          <%= invoice.items[0]?.deal?.companyName || invoice.items[0]?.deal?.dealName || "Client" %><br />
          <% if (invoice.items[0]?.deal?.address) { %>
            <%= invoice.items[0].deal.address %><br />
          <% } %>
          <% if (invoice.items[0]?.deal?.country) { %>
            <%= invoice.items[0].deal.country %><br />
          <% } %>
          <% if (invoice.items[0]?.deal?.email) { %>
            Email: <%= invoice.items[0].deal.email %><br />
          <% } %>
          <%
            const clientPhone =
              invoice.items[0]?.deal?.phoneNumber   ||
              invoice.items[0]?.deal?.phone         ||
              invoice.items[0]?.deal?.contactNumber ||
              invoice.items[0]?.deal?.mobile        ||
              "";
          %>
          <% if (clientPhone) { %>
            Phone: <%= clientPhone %>
          <% } %>
        </div>
      </div>

      <!-- Invoice Details -->
      <div class="invoice-details">
        <strong>Invoice Date:</strong>
        <%= new Date(invoice.createdAt).toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" }) %><br />
        <strong>Invoice Number:</strong> <%= invoice.invoicenumber %><br />
        <% if (invoice.dueDate) { %>
          <strong>Due Date:</strong>
          <%= new Date(invoice.dueDate).toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" }) %><br />
        <% } %>
        <strong>Status:</strong>
        <span style="
          display:inline-block;
          padding:2px 10px;
          border-radius:12px;
          font-size:11px;
          font-weight:bold;
          background-color:<%= invoice.status === 'paid' ? '#dcfce7' : '#fee2e2' %>;
          color:<%= invoice.status === 'paid' ? '#16a34a' : '#dc2626' %>;
        ">
          <%= (invoice.status || 'unpaid').toUpperCase() %>
        </span>
      </div>

      <!-- Table -->
      <table>
        <thead>
          <tr>
            <th>Client Name</th>
            <th>HSN/SAC Code</th>
            <th>Total Effort (Days)</th>
            <th class="right">Amount (<%= invoice.currency || "USD" %>)</th>
          </tr>
        </thead>
        <tbody>
          <% invoice.items.forEach(function(item) { %>
          <tr>
            <td><%= item.deal?.dealName || "" %></td>
            <td>998314</td>
            <td>30</td>
            <td class="right"><%= Number(item.amount || item.price || 0).toFixed(2) %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>

      <!-- Totals -->
      <div class="totals">
        <table class="totals-table">
          <tr>
            <td>Subtotal</td>
            <td><%= invoice.currency %> <%= Number(invoice.subtotal || 0).toFixed(2) %></td>
          </tr>

          <% const savedTaxAmount      = Number(invoice.taxAmount || 0); %>
          <% const savedDiscountAmount = Number(invoice.discount  || invoice.discountAmount || 0); %>
          <% const savedTotal          = Number(invoice.total     || 0); %>

          <% if (invoice.currency === "INR" && savedTaxAmount > 0) { %>
          <tr>
            <td>Tax<% if (invoice.taxType === "percentage" && invoice.tax > 0) { %> (<%= invoice.tax %>%)<% } %></td>
            <td><%= invoice.currency %> <%= savedTaxAmount.toFixed(2) %></td>
          </tr>
          <% } %>

          <% if (savedDiscountAmount > 0) { %>
          <tr>
            <td>Discount<% if (invoice.discountType === "percentage" && invoice.discountValue > 0) { %> (<%= invoice.discountValue %>%)<% } %></td>
            <td>- <%= invoice.currency %> <%= savedDiscountAmount.toFixed(2) %></td>
          </tr>
          <% } %>

          <tr class="total-row">
            <td>Total</td>
            <td><%= invoice.currency %> <%= savedTotal.toFixed(2) %></td>
          </tr>
        </table>
      </div>

      <!-- Footer -->
      <div class="footer">
        Terms &amp; Conditions: Payment due within 30 days.<br />
        Thank you for your business with U Enjoy Tours!<br />
        &copy; U Enjoy Tours | uenjoytours@gmail.com | +91 9535542288
      </div>

    </div>
  </body>
</html>